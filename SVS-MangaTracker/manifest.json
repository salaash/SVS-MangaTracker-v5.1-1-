{
  "manifest_version": 3,
  "name": "S.V.S Manga Tracker",
  "version": "5.0",
  "description": "Track your manga and manhwa reading across any site.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "permissions": ["storage", "activeTab", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": [
        "*://*.manganato.com/*", "*://*.chapmanganato.com/*",
        "*://*.mangakakalot.com/*", "*://*.asurascans.com/*",
        "*://*.asuracomic.net/*", "*://*.reaperscans.com/*",
        "*://*.webtoons.com/*", "*://*.toonily.com/*",
        "*://*.mangasee123.com/*", "*://*.flamescans.org/*",
        "*://*.flamecomics.me/*", "*://*.tcbscans.me/*",
        "*://*.manhuaus.com/*", "*://*.mangaread.org/*",
        "*://*.bato.to/*", "*://*.manhuafast.com/*",
        "*://*.isekaiscan.com/*", "*://*.mangatx.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
